  "keyFeatures": [
    "RAG-powered AI responses using document knowledge base",
    "WhatsApp Business API integration with webhook support",
    "Google Calendar integration for appointment scheduling",
    "Visual flow builder for custom conversation flows",
    "Dual bot modes: AI-powered and classic rule-based",
    "Audio transcription with OpenAI Whisper",
    "Vector similarity search with MySQL storage",
    "Real-time conversation management dashboard",
    "Document upload and processing (PDF, DOCX, TXT)",
    "Human handoff capabilities"
  ],
  "publicApiSurface": [
    "POST /webhook - WhatsApp webhook endpoint",
    "GET /api/conversations - List conversations",
    "GET /api/conversations/{id}/messages - Get conversation messages",
    "POST /api/conversations/{id}/reply - Send manual reply",
    "POST /api/conversations/{id}/toggle-ai - Toggle AI mode",
    "POST /api/upload - Upload document for RAG indexing",
    "GET /api/get-documents - List uploaded documents",
    "DELETE /api/delete-document - Remove document",
    "GET /api/get-settings - Get system settings",
    "POST /api/save-settings - Update settings",
    "GET /api/get-credentials - Get API credentials",
    "POST /api/save-credentials - Update credentials",
    "GET /api/get-flows - Get conversation flows",
    "POST /api/save-flow - Save conversation flow",
    "DELETE /api/delete-flow - Delete flow",
    "POST /api/simulate-flow - Test flow execution",
    "GET /api/health - System health check",
    "GET /api/stats - Dashboard statistics"
  ]
